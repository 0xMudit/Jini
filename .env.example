PORT=8788
NODE_ENV=production
LOG_LEVEL=info

# Leave empty when the frontend and API share an origin. For a separate API,
# use a full origin such as http://localhost:8788.
VITE_API_BASE=

# Optional. Without this key the app still answers using local extractive RAG.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ALLOWED_ORIGINS=
COOKIE_SECURE=false

# Set to "true" when behind a reverse proxy (nginx, Caddy, etc.)
TRUST_PROXY=false

# Optional seeded-account overrides for local testing.
TEST_USER_PASSWORD=JiniTest123!
HR_TEST_PASSWORD=JiniHR123!
GUEST_TEST_PASSWORD=JiniGuest123!
